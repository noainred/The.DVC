# VMware Global Monitoring Portal — runtime configuration (systemd EnvironmentFile)
# 수정 후:  systemctl restart vmware-portal

# --- core ---
PORT=4000
# 사용자 설정 저장 위치(앱 폴더 밖이라 업그레이드해도 보존됨): vcenters.json/users.json/upgrade.json
CONFIG_DIR=/etc/vmware-portal
# 데이터 소스: mock(데모) | live(실제 vCenter) | auto(실패 시 mock 대체)
DATA_SOURCE=mock
# vCenter 폴링 주기(ms)
POLL_INTERVAL_MS=30000
# 사설 vCenter 자체서명 인증서 검증 (true 면 검증, false 면 허용)
VC_TLS_REJECT_UNAUTHORIZED=false

# --- iDRAC 전력 수집 (Dell Redfish) ---
# 켜고 끄기(기본 on). 등록된 서버가 있을 때만 실제 수집합니다.
IDRAC_ENABLED=true
# 수집 주기(ms, 기본 60초)
IDRAC_POLL_INTERVAL_MS=60000
# 전력 이력 보관 일수(기본 90일, 0=무제한)
IDRAC_RETENTION_DAYS=90
# SQLite DB 경로(기본 $CONFIG_DIR/idrac-power.db — 업그레이드해도 보존)
# IDRAC_DB_PATH=/etc/vmware-portal/idrac-power.db
# [Active Directory(LDAP) 로그인] 설정 → 인증(AD) 메뉴에서도 구성 가능. env 예시:
#   AD_ENABLED=true
#   AD_URL=ldaps://dc.corp.local:636
#   AD_DOMAIN=corp.local                 # 로그인: user@corp.local 로 직접 바인드
#   AD_BASE_DN=DC=corp,DC=local          # memberOf(그룹) 조회용
#   AD_ADMIN_GROUP=VMware-Portal-Admins  # 이 그룹 멤버 → admin (operator/viewer 그룹도 가능)
#   AD_DEFAULT_ROLE=viewer               # 그룹 매칭 없을 때 기본 역할
#   AD_TLS_REJECT_UNAUTHORIZED=false     # 자체서명 인증서면 false
# AD 인증 실패 시 로컬 users.json 으로 폴백(기본 admin 유지).
#
# iDRAC 등록(서버명/IP/계정/매핑 호스트)은 포탈 관리자 → '전력 수집' 메뉴에서.
# 저장 위치: $CONFIG_DIR/idrac.json (0600)
# OME(OpenManage Enterprise) 전력 메트릭 튜닝(Power Manager): 전력값이 안 잡히면 조정.
#   OME_POWER_METRIC_TYPES=3,4,1   # 순서대로 시도(순간/평균/최대 시스템전력)
#   OME_POWER_DURATION=0           # 메트릭 조회 구간(0=최근)
#   OME_POWER_PLUGIN_ID=2F6D05BE-EE4B-4B0E-B873-C8D2F64A4625

# --- ★ 통합 엣지 모드 (권장: 엣지는 이 3줄이면 끝) ---
# 아래 3개만 설정하면 엣지의 전 기능이 켜집니다:
#   수집기 export + 위임 스캔/핑/캡처/로그 워커 + 사이트 인벤토리 push(live 수집)
#   + 중앙발 자동 업그레이드(/dl) + 부팅 시 중앙 자동 등록(수집 서버 수동 추가 불필요)
# EDGE_MODE=all
# CENTRAL_URL=http://중앙포탈:4000
# EDGE_TOKEN=강력한-공유-토큰        # 중앙의 CENTRAL_TOKEN과 같은 값
# (선택) COLLECTOR_DATACENTER=Poland-DC1   # 표시용 DC 이름(=AGENT_NAME 기본값)
# (선택) EDGE_ADVERTISE_URL=http://엣지실주소:4000  # NAT/프록시 뒤라면 명시
# 개별 env(DATA_SOURCE, AGENT_PUSH_INVENTORY, UPGRADE_* 등)를 쓰면 그 값이 우선합니다.

# --- 분산 수집 (대규모: 서버 1천대+ / DC 13개) ---
# 이 서버를 '수집 에이전트'로 만들려면 토큰과 데이터센터 이름을 설정하세요.
# 그러면 GET /api/collector/export 가 토큰으로 열리고, 중앙 포탈이 당겨갑니다.
# COLLECTOR_TOKEN=강력한-공유-토큰
# COLLECTOR_DATACENTER=Seoul-DC1
# 중앙 포탈에서 원격 수집기 당김 주기(ms, 기본 60초; 0이면 중앙 기능 비활성)
# COLLECTOR_PULL_INTERVAL_MS=60000
#
# [중앙 오케스트레이션] 에이전트에 IP를 할당해 원격 스캔시키기:
#  - 중앙 서버: CENTRAL_TOKEN 설정(에이전트 인증용). 관리자 → '에이전트 작업'에서 이름별 IP 할당.
#    CENTRAL_TOKEN=강력한-토큰
#  - 각 에이전트 서버: 자기 이름 + 중앙 주소 + 동일 토큰 설정. 할당분을 읽어 로컬 스캔 후 보고.
#    AGENT_NAME=Seoul-DC1
#    CENTRAL_URL=http://중앙포탈:4000
#    CENTRAL_TOKEN=강력한-토큰
#    AGENT_SCAN_INTERVAL_MS=3600000   # 스캔 주기(기본 1시간)
#    AGENT_AUTO_REGISTER=true         # 발견한 iDRAC 로컬 자동 등록(기본 on)

# --- auth ---
AUTH_ENABLED=true
# 토큰 서명 시크릿 — 설치 스크립트가 무작위로 채웁니다. 비우지 마세요.
AUTH_SECRET=
AUTH_TOKEN_TTL=8h
# users.json 미존재 시 시드되는 기본 admin 비밀번호 (운영 시 변경 권장)
DEFAULT_ADMIN_PASSWORD=admin123

# --- auto-upgrade (옵트인, 기본 비활성) ---
# UPGRADE_ENABLED=true
# UPGRADE_INSTALL_DIR=/opt/vmware-portal/app
#
# (A) GitHub versions.json 모니터링 후 자동 업그레이드:
#   UPGRADE_POLL_INTERVAL_MS=3600000   # 1시간마다 확인
#   UPGRADE_AUTO_APPLY=true            # 새 버전이면 자동 적용 + 재시작
#   감시 경로(remote base, 비우면 GitHub download/ 기본값 사용):
#   UPGRADE_REMOTE_BASE=https://raw.githubusercontent.com/noainred/The.DVC/main/download
#   (사설 레포면 PAT) UPGRADE_TOKEN=ghp_xxx
#
# (B) 로컬 감시 폴더 방식:
#   UPGRADE_WATCH_DIR=/opt/vmware-portal/incoming
#
# (선택) 자가 업그레이드 후 엣지에 푸시: UPGRADE_EDGES=[{"url":"https://edge1","token":"..."}]
