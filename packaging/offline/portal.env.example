# VMware Global Monitoring Portal — runtime configuration (systemd EnvironmentFile)
# 수정 후:  systemctl restart vmware-portal

# --- core ---
PORT=4000
# 데이터 소스: mock(데모) | live(실제 vCenter) | auto(실패 시 mock 대체)
DATA_SOURCE=mock
# vCenter 폴링 주기(ms)
POLL_INTERVAL_MS=30000
# 사설 vCenter 자체서명 인증서 검증 (true 면 검증, false 면 허용)
VC_TLS_REJECT_UNAUTHORIZED=false

# --- auth ---
AUTH_ENABLED=true
# 토큰 서명 시크릿 — 설치 스크립트가 무작위로 채웁니다. 비우지 마세요.
AUTH_SECRET=
AUTH_TOKEN_TTL=8h
# users.json 미존재 시 시드되는 기본 admin 비밀번호 (운영 시 변경 권장)
DEFAULT_ADMIN_PASSWORD=admin123

# --- auto-upgrade (옵트인, 기본 비활성) ---
# UPGRADE_ENABLED=true
# UPGRADE_WATCH_DIR=/opt/vmware-portal/incoming
# UPGRADE_INSTALL_DIR=/opt/vmware-portal/app
# UPGRADE_POLL_INTERVAL_MS=300000
# UPGRADE_AUTO_APPLY=false
# UPGRADE_REMOTE_BASE=
# UPGRADE_TOKEN=
# UPGRADE_EDGES=
